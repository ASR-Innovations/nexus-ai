# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
API_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/nexusai_protocol
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexusai_protocol
DB_USER=username
DB_PASSWORD=password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=120

# Blockchain Configuration
POLKADOT_HUB_RPC_URL=https://polkadot-asset-hub-rpc.polkadot.io
POLKADOT_HUB_WS_URL=wss://polkadot-asset-hub-rpc.polkadot.io
HYDRATION_RPC_URL=wss://rpc.hydradx.cloud
BIFROST_RPC_URL=wss://bifrost-rpc.liebi.com/ws
MOONBEAM_RPC_URL=wss://wss.api.moonbeam.network

# Contract Addresses (deployed contract addresses)
INTENT_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
EXECUTION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

# AI Services Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.1

# Memory Service Configuration
MEM0_API_KEY=your_mem0_api_key_here
MEM0_BASE_URL=https://api.mem0.ai
MEM0_USER_ID_PREFIX=nexus-ai-v1
MEM0_AGENT_ID=nexus-ai-v1

# External APIs
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=your_coingecko_api_key_optional

# Rate Limiting Configuration
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_INTENT_PER_MINUTE=5
RATE_LIMIT_PORTFOLIO_PER_MINUTE=20
RATE_LIMIT_WINDOW_MS=60000

# Caching Configuration
CACHE_YIELD_DATA_TTL=120
CACHE_PORTFOLIO_TTL=30
CACHE_DEEPSEEK_TTL=60
CACHE_AGENT_METADATA_TTL=300

# Indexer Configuration
INDEXER_START_BLOCK=latest
INDEXER_BATCH_SIZE=100
INDEXER_REORG_DEPTH=10
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_XCM_CONFIRMATION_TIMEOUT=300000

# WebSocket Configuration
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000

# Security Configuration
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SIGNATURE_TIMEOUT_MS=300000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILES=7
LOG_MAX_SIZE=10m

# Monitoring Configuration
SENTRY_DSN=your_sentry_dsn_here_optional
METRICS_ENABLED=true
HEALTH_CHECK_TIMEOUT=5000

# Gas Estimation Configuration
GAS_ESTIMATION_BUFFER_PERCENT=20
GAS_PRICE_ORACLE_URL=https://api.etherscan.io/api
DEFAULT_GAS_LIMIT=500000

# Yield Aggregator Configuration
YIELD_REFRESH_INTERVAL_NATIVE=60000
YIELD_REFRESH_INTERVAL_PARACHAIN=120000
YIELD_SNAPSHOT_INTERVAL=600000
YIELD_CACHE_FALLBACK_ENABLED=true

# Strategy Engine Configuration
STRATEGY_MAX_RESULTS=3
STRATEGY_RISK_WEIGHTS_CONTRACT=0.3
STRATEGY_RISK_WEIGHTS_IL=0.2
STRATEGY_RISK_WEIGHTS_LOCK=0.2
STRATEGY_RISK_WEIGHTS_TVL=0.15
STRATEGY_RISK_WEIGHTS_VOLATILITY=0.15

# Development Configuration
DEBUG_ENABLED=false
MOCK_EXTERNAL_APIS=false
SKIP_SIGNATURE_VERIFICATION=false
ENABLE_API_DOCS=true
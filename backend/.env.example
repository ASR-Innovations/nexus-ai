BEAMSWAP_ROUTER_ADDRESS=0x96b244391D98B62D19aE89b1A4dCcf0fc56970C7
BEAMSWAP_FACTORY_ADDRESS=0x985BcA32293A7A496300a48081947321177a86FD

# ============================================================================
# Gas and Execution Configuration
# ============================================================================

# Gas Configuration
GAS_PRICE_CACHE_TTL_MS=15000
MAX_GAS_PRICE_GWEI=500
MIN_GAS_PRICE_GWEI=1
GAS_PRICE_MULTIPLIER_LOW=0.9
GAS_PRICE_MULTIPLIER_MEDIUM=1.0
GAS_PRICE_MULTIPLIER_HIGH=1.3
GAS_ESTIMATION_BUFFER_PERCENT=20
DEFAULT_GAS_LIMIT=500000

# Execution Configuration
MAX_EXECUTION_RETRIES=3
BASE_RETRY_DELAY_MS=1000
MAX_RETRY_DELAY_MS=30000
EXECUTION_TIMEOUT_MS=300000
EXECUTION_PREREQUISITE_CHECK_ENABLED=true
CONCURRENT_EXECUTION_MAX=5
BATCH_TRANSACTION_MAX_SIZE=10

# XCM Configuration
XCM_MESSAGE_TIMEOUT_MS=300000
XCM_RETRY_DELAY_MS=5000
XCM_MAX_RETRIES=3
XCM_FEE_BUFFER_PERCENT=10

# ============================================================================
# Security and Compliance Configuration
# ============================================================================

# Encryption Configuration
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters_required
ENCRYPTION_ENABLED=true

# HSM/KMS Configuration
KMS_ENABLED=false
KMS_PROVIDER=local  # Options: aws-kms, azure-keyvault, local
KMS_KEY_ID=
KMS_ENDPOINT=

# AWS KMS (if KMS_PROVIDER=aws-kms)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ARN=

# Azure Key Vault (if KMS_PROVIDER=azure-keyvault)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=

# Activity Monitoring Thresholds
ACTIVITY_HIGH_FREQUENCY_THRESHOLD=10  # transactions per minute
ACTIVITY_LARGE_AMOUNT_THRESHOLD=100000000000000000000  # 100 tokens in wei
ACTIVITY_RAPID_SUCCESSION_WINDOW=60000  # milliseconds

# Role-Based Access Control
RBAC_ENABLED=true
RBAC_DEFAULT_ROLE=viewer

# Circuit Breaker Configuration
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT_MS=60000
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# Error Handling Configuration
ERROR_TRACKING_ENABLED=true
ERROR_HISTORY_MAX_ENTRIES=10000
ERROR_NOTIFICATION_ENABLED=true
ERROR_NOTIFICATION_WEBHOOK=

# Fund Manager Configuration
FUND_MANAGER_AUDIT_LOG_ENABLED=true
FUND_MANAGER_BALANCE_CACHE_TTL_MS=30000
FUND_MANAGER_EMERGENCY_PAUSE_ENABLED=true

# ============================================================================
# Monitoring and Alerting Configuration
# ============================================================================

# Health Monitoring
PROTOCOL_HEALTH_CHECK_INTERVAL_MS=60000
PROTOCOL_HEALTH_ALERT_THRESHOLD=3
PROTOCOL_HEALTH_RECOVERY_CHECKS=2
HEALTH_CHECK_TIMEOUT=5000

# Metrics and Observability
METRICS_ENABLED=true
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Alerting Integrations
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
PAGERDUTY_ROUTING_KEY=

# Alert Thresholds
ALERT_EXECUTION_FAILURE_THRESHOLD=3  # consecutive failures
ALERT_GAS_PRICE_SPIKE_THRESHOLD=200  # % increase
ALERT_BALANCE_LOW_THRESHOLD=1000000000000000000  # 1 token in wei
ALERT_REPUTATION_DROP_THRESHOLD=500  # reputation points

# Logging Configuration
LOG_LEVEL=info  # Options: error, warn, info, debug, verbose
LOG_FORMAT=json  # Options: json, text
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILES=7
LOG_MAX_SIZE=10m
VERBOSE_LOGGING=false

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn_here_optional
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# Performance Configuration
# ============================================================================

# Connection Pooling
CONNECTION_POOL_SIZE=10
CONNECTION_POOL_TIMEOUT_MS=30000

# Performance Tuning
BATCH_TRANSACTION_MAX_SIZE=10
CONCURRENT_EXECUTION_MAX=5

# ============================================================================
# Development and Testing Configuration
# ============================================================================

# Development Mode
TESTNET_MODE=false  # Set to true for testnet, false for mainnet
SKIP_WALLET_VALIDATION=false
MOCK_PROTOCOL_RESPONSES=false
DRY_RUN_MODE=false  # Set to true to simulate without real transactions
DEBUG_ENABLED=false
ENABLE_API_DOCS=true

# ============================================================================
# Deployment Configuration
# ============================================================================

# Environment
NODE_ENV=production  # Options: development, staging, production

# Network Configuration
DEPLOYMENT_NETWORK=mainnet  # Options: testnet, mainnet
DEPLOYMENT_REGION=us-east-1

# Scaling Configuration
MIN_INSTANCES=2
MAX_INSTANCES=10
AUTO_SCALING_ENABLED=true
CPU_THRESHOLD=70
MEMORY_THRESHOLD=80

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
DISASTER_RECOVERY_ENABLED=true
